[Desktop Entry]
Name=SONE
Comment=Native Linux client for TIDAL — lossless and bit-perfect audio streaming
Categories=Audio;Music;AudioVideo;
Exec=io.github.lullabyX.sone %u
MimeType=x-scheme-handler/tidal;
Icon=io.github.lullabyX.sone
Terminal=false
Type=Application
StartupWMClass=sone
GenericName=TIDAL Music Client
StartupNotify=true
Keywords=music;audio;streaming;tidal;player;hifi;lossless;flac;
